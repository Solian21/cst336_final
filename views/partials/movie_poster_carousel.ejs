<% if (movies.length > 0) { %>

  <div id="carouselExampleControls" class="carousel slide" data-bs-ride="carousel" style="width: 300px; margin: auto;">

    <div class="carousel-inner">

      <!-- FIRST ITEM (ACTIVE) -->
      <div class="carousel-item active">
        <img
          class="d-block w-100"
          src="https://image.tmdb.org/t/p/w500<%= movies[0].posterPath %>"
          alt="<%= movies[0].title %> poster">
      </div>

      <!-- REST OF MOVIES -->
      <% for (let i = 1; i < movies.length; i++) { %>
        <div class="carousel-item">
          <img
            class="d-block w-100"
            src="https://image.tmdb.org/t/p/w500<%= movies[i].posterPath %>"
            alt="<%= movies[i].title %> poster">
          
        </div>
      <% } %>

    </div>

    <!-- CONTROLS -->
    <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleControls" data-bs-slide="prev">
      <span class="carousel-control-prev-icon"></span>
    </button>

    <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleControls" data-bs-slide="next">
      <span class="carousel-control-next-icon"></span>
    </button>

  </div>

<% } else { %>
  <p class="text-center">No movies found.</p>
<% } %>